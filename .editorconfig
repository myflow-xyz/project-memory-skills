# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
max_line_length = 100

# Markdown files
[*.md]
indent_size = 4
trim_trailing_whitespace = false
max_line_length = 140

# YAML files
[*.{sh,json,yml,yaml}]
indent_style = space
indent_size = 2

# TOML
[*.{toml,ini}]
indent_size = 4
indent_style = space

# TypeScript and JavaScript files
[*.{js,jsx,ts,tsx,mjs}]
indent_style = space
indent_size = 2
quote_type = single

# Configuration files
[.{editorconfig,prettierrc,eslintrc,conf}]
indent_size = 2

